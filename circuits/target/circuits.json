{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"13721136454340579330","abi":{"parameters":[{"name":"balances","type":{"kind":"array","length":10,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"total_supply","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"threshold_pct","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"}],"return_type":null,"error_types":{"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"// Proof of Reserves Circuit\n// Proves that the sum of private balances >= public threshold\n// without revealing individual balances\n\nfn main(\n    // Private inputs - never revealed\n    balances: [u64; 10],\n    \n    // Public inputs - visible to verifier\n    total_supply: pub u64,\n    threshold_pct: pub u64\n) {\n    let mut total_reserves: u64 = 0;\n    for i in 0..10 {\n        total_reserves = total_reserves + balances[i];\n    }\n\n    let required: u64 = (total_supply * threshold_pct) / 100;\n    assert(total_reserves >= required);\n}\n\n#[test]\nfn test_sufficient_reserves() {\n    let balances: [u64; 10] = [\n        1000, 2000, 3000, 500, 750,\n        1200, 800, 900, 1500, 350\n    ];\n    main(balances, 10000, 100);\n}\n","path":"/workspaces/stellar-proof-of-reserves/circuits/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient"]}